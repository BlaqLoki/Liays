# Copy this file to .env.local and fill in real values for local dev.
# In production (Vercel), set these in Project Settings > Environment Variables instead.

# Get an API key at https://resend.com after creating an account.
RESEND_API_KEY=

# Where contact form submissions should be delivered.
CONTACT_TO_EMAIL=hello@liaysinc.com

# Must be on a domain verified in Resend. Leave as onboarding@resend.dev for
# early testing (limited), or set to something like hello@yourdomain.com once
# your real domain's DNS records are verified in Resend.
RESEND_FROM_EMAIL=onboarding@resend.dev
