# Copy this file to .env.local and fill in real values for local dev.
# In production (Vercel), set these in Project Settings > Environment Variables instead.

# Get an API key at https://resend.com after creating an account.
RESEND_API_KEY=

# Where contact form submissions should be delivered — the real Hostinger inbox.
CONTACT_TO_EMAIL=info@liays.ca

# Must be on a domain verified in Resend. Leave as onboarding@resend.dev for
# early testing (limited), or set to something like notifications@liays.ca
# once liays.ca is verified in Resend. Note: Hostinger's mailbox for
# liays.ca already owns MX/SPF for receiving mail — when adding Resend's
# SPF/DKIM records, merge into the existing SPF TXT record rather than
# adding a second one, or verify a subdomain (e.g. send.liays.ca) instead
# to avoid any conflict with Hostinger's own mail setup.
RESEND_FROM_EMAIL=onboarding@resend.dev
